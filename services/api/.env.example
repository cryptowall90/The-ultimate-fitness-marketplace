# services/api environment. Names only — never commit real values.

# development | test | production
NODE_ENV=development
PORT=8787

# Postgres connection string (Supabase direct connection / local dev database)
DATABASE_URL=

# Supabase JWT secret used to verify user access tokens (server-only)
SUPABASE_JWT_SECRET=

# Stripe secret API key (server-only, never in client bundles)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for this endpoint (server-only)
STRIPE_WEBHOOK_SECRET=

# Random >=32 char token authenticating scheduled job invocations (cron)
JOB_TOKEN=

# Comma-separated list of allowed browser origins
ALLOWED_ORIGINS=http://localhost:3000

# Public web app base URL used for redirect targets
APP_BASE_URL=http://localhost:3000

# Supabase project URL (storage REST API base)
SUPABASE_URL=

# Supabase service-role key (server-only, never in client bundles)
SUPABASE_SERVICE_ROLE_KEY=
