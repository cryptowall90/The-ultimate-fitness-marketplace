    "zod": "3.23.8"
  },
  "devDependencies": {
    "@fitmarket/database": "workspace:*",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "eslint": "9.17.0",
    "stripe": "17.5.0",
