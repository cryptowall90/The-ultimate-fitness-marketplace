# apps/web environment. Names only — never commit real values.
# NEXT_PUBLIC_* variables are shipped to the browser: PUBLIC VALUES ONLY.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Server-only (never NEXT_PUBLIC_): used by server components/route handlers.
# The service-role key is intentionally NOT configured here — the web app never
# uses it; privileged operations live in services/api.
